	<subDataset name="Salary History" uuid="b9802b32-21ba-401d-b180-568dfda1ffb5">
		<parameter name="DOC_KEY_POID" class="java.lang.String">
			<defaultValueExpression><![CDATA[961]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT LAST_INCREMENT_DATE, BASIC_SALARY, FA_ALW, TA_ALW, HRA_ALW, FIXOT_ALW, GROSS_PAY, DESIGNATION_POID, TICKET_PERIOD, NO_OF_TICKETS, 'HISTORY' as REMARKS
FROM PRODUCTION_PAYROLL.HR_EMPLOYEE_SALARY_HIST
WHERE SALARY_POID = $P{DOC_KEY_POID}]]>
		</queryString>
		<field name="LAST_INCREMENT_DATE" class="java.sql.Timestamp"/>
		<field name="BASIC_SALARY" class="java.math.BigDecimal"/>
		<field name="FA_ALW" class="java.math.BigDecimal"/>
		<field name="TA_ALW" class="java.math.BigDecimal"/>
		<field name="HRA_ALW" class="java.math.BigDecimal"/>
		<field name="FIXOT_ALW" class="java.math.BigDecimal"/>
		<field name="GROSS_PAY" class="java.math.BigDecimal"/>
		<field name="DESIGNATION_POID" class="java.math.BigDecimal"/>
		<field name="TICKET_PERIOD" class="java.math.BigDecimal"/>
		<field name="NO_OF_TICKETS" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
	</subDataset>
	<parameter name="DOC_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DOC_KEY_POID" class="java.lang.String">
		<defaultValueExpression><![CDATA[961]]></defaultValueExpression>
	</parameter>
	<parameter name="LOGIN_COMP_POID" class="java.lang.String">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["\\\\10.100.100.3\\erp_reports\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUB_HEADER" class="net.sf.jasperreports.engine.JasperReport"/>
	<parameter name="PRINTED_FROM_MASTER" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT EM.EMPLOYEE_POID, EMPLOYEE_CODE, EMPLOYEE_NAME, EMPLOYEE_NAME2, EMPLOYEE_NAME || ' ' || EMPLOYEE_NAME2 as EMPLOYEE_NAME_FULL,
      PHOTO, JOIN_DATE, GENDER, MARITAL_STATUS, DATE_OF_BIRTH,
	PRESENT_ADDRESS, PERMANENT_ADDRESS, MOBILE, PERSONAL_EMAIL, BUSINESS_EMAIL, AIR_SECTOR_POID, TICKET_PERIOD, NO_OF_TICKETS,
	DISCONTINUED, DISCONTINUED_DATE, CR_NUMBER, PASSPORT_NO, EXPIRY_DATE, PASSPORT_REMARKS, PLACE_OF_HIRE,
	CPR_NO, CPR_EXPIRY_DATE, CPR_OCCUPATION, MEDICAL_INSURANCE, EM.LIFE_INSURANCE,
	EM.EMERGENCY_CONTACT_NO, EM.EMERGENCY_CONTACT_PERSON, EM.JOB_DESCRIPTION,
	RP_NO, RP_EXPIRY_DATE, DESIGNATION_NAME, DEPT_NAME, D.DESIGNATION_NAME, DA.DEPT_NAME, DA.DEPT_CODE, NATIONALITY_DESCRIPTION as NATIONALITY, SM.*,
      -1*PRODUCTION.FUNC_GL_LEDGER_BALANCE(1,EMP_GL_POID,SYSDATE) as LOAN_BALANCE, EXPERIENCE
  FROM HR_EMPLOYEE_MASTER EM
  LEFT OUTER JOIN HR_DESIGNATION_MASTER D ON EM.DESIGNATION_POID = D.DESIG_POID
  LEFT OUTER JOIN HR_DEPARTMENT_MASTER DA ON EM.DEPARTMENT_POID = DA.DEPT_POID
  LEFT OUTER JOIN HR_NATIONALITY_MASTER NM ON EM.NATIONALITY_POID = NM.NATION_POID
  LEFT JOIN ADMIN_CR_MASTER CR ON CR.CR_POID = EM.CR_POID
  LEFT JOIN (
      SELECT EMPLOYEE_POID,
      LISTAGG(DESIGNATION || ', ' || EMPLOYER || ', ' || COUNTRY_LOCATION || ', From ' ||FROM_DATE || ' to ' || TO_DATE
      ,' ; ') WITHIN GROUP (ORDER BY DET_ROW_ID) EXPERIENCE
      FROM HR_EMPLOYEE_EXPERIENCE_DTL
      GROUP BY EMPLOYEE_POID
  )EXP ON EXP.EMPLOYEE_POID = EM.EMPLOYEE_POID
  LEFT OUTER JOIN
	(SELECT SM.EMPLOYEE_POID, SM.BASIC_SALARY, SM.REGISTERED_SALARY,
		SM.LAST_INCREMENT_DATE , SM.GROSS_SALARY, SM.PAYMENT_METHOD, BANK.BANK_CODE, SM.IBAN_ACCOUNT_NO, SM.BANK_GUARANTEE, SM.BANK_GUARANTEE_DETAILS,
		SUM(NVL(FXALW.AMOUNT, 0))AS FIXED_ALLOWANCE,
		SUM(NVL(HRAALW.AMOUNT, 0))AS HRA_ALLOWANCE, SUM(NVL(TRNSP.AMOUNT, 0))AS TRANSPORT_ALLOWANCE, SUM(NVL(FXOT.AMOUNT, 0))AS FIXED_OT,
		SUM(NVL(TELALW.AMOUNT, 0))AS TEL_ALLOWANCE

	  FROM TEST_PAYROLL.HR_EMPLOYEE_SALARY_MASTER SM
	  LEFT JOIN TEST_PAYROLL.HR_EMPLOYEE_SALARY_ALW_DTL FXALW ON FXALW.SALARY_POID = SM.SALARY_POID AND FXALW.ALLOWANCE_DEDUCTION_POID IN(
		SELECT ALLOWACE_DEDUCTION_POID
		  FROM TEST_PAYROLL.HR_ALLOWANCE_DEDUCTION_MASTER
		 WHERE CODE = 'FXALW'
	)
	  LEFT JOIN TEST_PAYROLL.HR_EMPLOYEE_SALARY_ALW_DTL FXOT ON FXOT.SALARY_POID = SM.SALARY_POID AND FXOT.ALLOWANCE_DEDUCTION_POID IN(
		SELECT ALLOWACE_DEDUCTION_POID
		  FROM TEST_PAYROLL.HR_ALLOWANCE_DEDUCTION_MASTER
		 WHERE CODE = 'FXOT'
	)
	  LEFT JOIN TEST_PAYROLL.HR_EMPLOYEE_SALARY_ALW_DTL HRAALW ON HRAALW.SALARY_POID = SM.SALARY_POID AND HRAALW.ALLOWANCE_DEDUCTION_POID IN(
		SELECT ALLOWACE_DEDUCTION_POID
		  FROM TEST_PAYROLL.HR_ALLOWANCE_DEDUCTION_MASTER
		 WHERE CODE = 'HRAALW'
	)
	  LEFT JOIN TEST_PAYROLL.HR_EMPLOYEE_SALARY_ALW_DTL TRNSP ON TRNSP.SALARY_POID = SM.SALARY_POID AND TRNSP.ALLOWANCE_DEDUCTION_POID IN(
		SELECT ALLOWACE_DEDUCTION_POID
		  FROM TEST_PAYROLL.HR_ALLOWANCE_DEDUCTION_MASTER
		 WHERE CODE = 'TRNSP'
	)
	  LEFT JOIN TEST_PAYROLL.HR_EMPLOYEE_SALARY_ALW_DTL TELALW ON TRNSP.SALARY_POID = SM.SALARY_POID AND TELALW.ALLOWANCE_DEDUCTION_POID IN(
		SELECT ALLOWACE_DEDUCTION_POID
		  FROM TEST_PAYROLL.HR_ALLOWANCE_DEDUCTION_MASTER
		 WHERE CODE = 'TELALW'
	)
	LEFT JOIN GLOBAL_CUSTOMER_BANK_MASTER BANK ON BANK.BANK_POID = SM.BANK_POID
	 GROUP BY  SM.EMPLOYEE_POID, SM.BASIC_SALARY, SM.REGISTERED_SALARY,
		SM.LAST_INCREMENT_DATE , SM.GROSS_SALARY, SM.PAYMENT_METHOD, BANK.BANK_CODE, SM.IBAN_ACCOUNT_NO, SM.BANK_GUARANTEE, SM.BANK_GUARANTEE_DETAILS
	) SM   ON EM.EMPLOYEE_POID = SM.EMPLOYEE_POID
 WHERE EM.EMPLOYEE_POID = $P{DOC_KEY_POID}]]>
	</queryString>
