<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Emp_leave_Request_subreport1" language="groovy" pageWidth="595" pageHeight="842" columnWidth="595" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="c10a37d5-da72-4376-9ed1-2409c702f5bc">
	<property name="ireport.zoom" value="2.357947691000002"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="P_TRN_NO" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 1 as DET_ROW_ID , HDR.TRANSACTION_POID,  TO_CHAR(EM.EMPLOYEE_NAME || ' ' || EM.EMPLOYEE_NAME2) as PERSONS_NAME , '12_YRS_AND_ABOVE' TICKET_AGE_GROUP, NULL as RELATION, NULL as DATE_FROM,  NULL as DATE_TO,  NULL as  REMARKS
FROM  HR_LEAVE_REQUEST_HDR HDR
INNER JOIN HR_EMPLOYEE_MASTER EM ON HDR.EMPLOYEE_POID = EM.EMPLOYEE_POID
WHERE HDR.TRANSACTION_POID = $P{P_TRN_NO}
UNION ALL
SELECT DTL.DET_ROW_ID + 1 DET_ROW_ID , DTL.TRANSACTION_POID, DTL.NAME as PERSONS_NAME , DTL.TICKET_AGE_GROUP, DTL.RELATION, DTL.DATE_FROM, DTL.DATE_TO, DTL.REMARKS
FROM  HR_LEAVE_REQUEST_DTL DTL
INNER JOIN HR_LEAVE_REQUEST_HDR HDR ON DTL.TRANSACTION_POID = HDR.TRANSACTION_POID
WHERE HDR.TRANSACTION_POID = $P{P_TRN_NO}]]>
	</queryString>
	<field name="DET_ROW_ID" class="java.math.BigDecimal"/>
	<field name="TRANSACTION_POID" class="java.math.BigDecimal"/>
	<field name="PERSONS_NAME" class="java.lang.String"/>
	<field name="TICKET_AGE_GROUP" class="java.lang.String"/>
	<field name="RELATION" class="java.lang.String"/>
	<field name="DATE_FROM" class="java.sql.Timestamp"/>
	<field name="DATE_TO" class="java.sql.Timestamp"/>
	<field name="REMARKS" class="java.lang.String"/>
