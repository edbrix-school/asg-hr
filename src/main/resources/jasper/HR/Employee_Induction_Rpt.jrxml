	<queryString>
		<![CDATA[select INDH.EMPLOYEE_POID,INDH.DOC_REF,INDH.TRANSACTION_POID,
EMP.EMPLOYEE_CODE,EMP.EMPLOYEE_NAME,DEP.DEPT_NAME,EMP.JOB_DESCRIPTION,
DES.DESIGNATION_NAME,EMP2.DISPLAY_NAME HEAD_OF_DEPT,EMP.DISPLAY_NAME
from HR_EMPLOYEE_TRAINING_HDR INDH
INNER JOIN HR_EMPLOYEE_MASTER EMP ON INDH.EMPLOYEE_POID=EMP.EMPLOYEE_POID
LEFT JOIN HR_DEPARTMENT_MASTER DEP ON EMP.DEPARTMENT_POID=DEP.DEPT_POID
LEFT JOIN HR_EMPLOYEE_MASTER EMP2 ON EMP.DIRECT_SUPERVISOR_POID=EMP2.EMPLOYEE_POID
LEFT JOIN HR_DESIGNATION_MASTER DES ON EMP.DESIGNATION_POID=DES.DESIG_POID
WHERE INDH.TRANSACTION_POID=$P{DOC_KEY_POID}]]>
	</queryString>
