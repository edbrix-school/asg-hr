	<queryString>
		<![CDATA[SELECT GROUP_POID,COMPANY_POID,TRANSACTION_POID,TRANSACTION_DATE, EMPLOYEE_POID,GET_EMPLOYEE_CODE(EMPLOYEE_POID)EMP_CODE,GET_EMPLOYEE_NAME(
      EMPLOYEE_POID)EMP_NAME, LEAVE_TYPE,CONTACT_NUMBER,LEAVE_START_DATE,PLANED_REJOIN_DATE,LEAVE_DAYS,ELIGIBLE_LEAVE_DAYS, BALANCE_LEAVE_DAYS,
